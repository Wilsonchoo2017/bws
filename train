#!/usr/bin/env python3
"""Train growth models offline and save to disk.

Usage:
    ./train                     # train active model (from config/model_registry.py)
    ./train --model keepa_bl    # train Keepa+BL model
    ./train --model legacy_be   # train legacy BE model
    ./train --no-save           # dry run
    ./train --no-backtest       # skip backtest (faster)
"""

import argparse
import logging
import sys
import time
import warnings
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
warnings.filterwarnings("ignore")

logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s %(name)-30s %(message)s",
    datefmt="%H:%M:%S",
)
logger = logging.getLogger("bws.train")


def main() -> None:
    parser = argparse.ArgumentParser(description="Train BWS growth models")
    parser.add_argument("--model", choices=["keepa_bl", "legacy_be"],
                        default=None, help="Model type (default: from config)")
    parser.add_argument("--no-save", action="store_true", help="Dry run, don't save")
    parser.add_argument("--no-backtest", action="store_true", help="Skip backtest")
    args = parser.parse_args()

    from config.model_registry import ACTIVE_MODEL
    model_type = args.model or ACTIVE_MODEL
    logger.info("Training model: %s", model_type)

    from db.pg.engine import get_engine
    from services.ml.growth.persistence import save_growth_models

    engine = get_engine()

    great_buy_classifier = None
    if model_type == "keepa_bl":
        tier1, tier2, theme_stats, subtheme_stats, classifier, ensemble, great_buy_classifier = _train_keepa_bl(engine)
    else:
        tier1, tier2, theme_stats, subtheme_stats, classifier, ensemble = _train_legacy_be(engine)

    # Model summary
    print(f"\n{'=' * 65}")
    print(f"  MODEL SUMMARY ({model_type})")
    print(f"{'=' * 65}")
    if tier1 is not None:
        print(f"  Regressor: {tier1.n_train} sets, {len(tier1.feature_names)} features, "
              f"CV R2={tier1.cv_r2_mean:.3f}")
    else:
        print("  Regressor: None (classifier-only)")
    if classifier:
        print(f"  Classifier: {classifier.n_train} sets, "
              f"AUC={classifier.cv_auc:.3f}, F1={classifier.cv_f1:.3f}, "
              f"Recall={classifier.cv_recall:.3f}")
    if great_buy_classifier:
        print(f"  Great-Buy: {great_buy_classifier.n_train} sets, "
              f"AUC={great_buy_classifier.cv_auc:.3f}, F1={great_buy_classifier.cv_f1:.3f}, "
              f"Recall={great_buy_classifier.cv_recall:.3f}")

    if not args.no_save:
        path = save_growth_models(
            tier1, tier2, theme_stats, subtheme_stats, classifier, ensemble,
            model_type=model_type,
            great_buy_classifier=great_buy_classifier,
        )
        logger.info("Models saved to %s", path)
    else:
        logger.info("Dry run -- models not saved")


def _train_keepa_bl(engine):
    """Train the Keepa+BL model (Experiment 31) + GT features (Exp 32)."""
    from services.ml.growth.keepa_training import train_keepa_bl_models
    from services.ml.pg_queries import load_google_trends_data, load_keepa_bl_training_data

    logger.info("Loading Keepa+BL training data...")
    base_df, keepa_df, target_series = load_keepa_bl_training_data(engine)
    gt_df = load_google_trends_data(engine)
    logger.info("Loaded %d base sets, %d Keepa sets, %d targets, %d GT sets",
                len(base_df), len(keepa_df), len(target_series), len(gt_df))

    t0 = time.time()
    result = train_keepa_bl_models(
        base_df=base_df, keepa_df=keepa_df, target_series=target_series,
        gt_df=gt_df,
    )
    logger.info("Training completed in %.1f minutes", (time.time() - t0) / 60)
    return result


def _train_legacy_be(engine):
    """Train the legacy BE model (original production model)."""
    from services.ml.growth.training import train_growth_models
    from services.ml.pg_queries import load_growth_training_data, load_keepa_timelines

    logger.info("Loading legacy BE training data...")
    df_raw = load_growth_training_data(engine)
    keepa_df = load_keepa_timelines(engine)
    logger.info("Loaded %d training sets, %d Keepa rows", len(df_raw), len(keepa_df))

    t0 = time.time()
    result = train_growth_models(df_raw=df_raw, keepa_df=keepa_df)
    logger.info("Training completed in %.1f minutes", (time.time() - t0) / 60)
    return result


if __name__ == "__main__":
    main()
